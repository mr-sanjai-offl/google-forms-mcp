# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Optional: Path to OAuth client secrets JSON file (alternative to individual env vars above)
# GOOGLE_CLIENT_SECRETS_FILE=path/to/client_secret.json

# Optional: Path to service account key file (for server-to-server auth)
# GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service_account.json

# Optional: Token storage location (defaults to ~/.google-forms-mcp/token.json)
# GOOGLE_FORMS_MCP_TOKEN_PATH=~/.google-forms-mcp/token.json

# Optional: Transport mode (stdio or http, defaults to stdio)
# GOOGLE_FORMS_MCP_TRANSPORT=stdio

# Optional: HTTP port (only used when transport is http, defaults to 8000)
# GOOGLE_FORMS_MCP_PORT=8000

# Optional: Log level (DEBUG, INFO, WARNING, ERROR, defaults to INFO)
# GOOGLE_FORMS_MCP_LOG_LEVEL=INFO
